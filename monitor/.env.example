# 已切换为真实发送模式。SMTP_PASSWORD 填好前请先不要启动自动监测。
EMAIL_DRY_RUN=false
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-auth-code
EMAIL_SENDER=your-email@qq.com
NOTIFY_EMAIL=your-email@qq.com
EMAIL_BODY_MODE=llm
EMAIL_LLM_PROVIDER=deepseek
EMAIL_CONTEXT_MARKDOWN=your-email-context-markdown
EMAIL_LLM_TIMEOUT_SECONDS=25
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_API_KEY=your-openai-api-key

# 单人志愿服务提醒 + 邮件回复确认报名。默认关闭，未来启用时改成 true。
VOLUNTEER_MONITOR_ENABLED=true
VOLUNTEER_CONFIRM_BY_EMAIL=true
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_USER=your-email@qq.com
IMAP_PASSWORD=your-smtp-auth-code
MAIL_TRIGGER_POLL_SECONDS=60

# 服务器版飞书应用机器人配置
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-secret
FEISHU_VERIFICATION_TOKEN=your-token
FEISHU_ENCRYPT_KEY=
FEISHU_DEFAULT_CHAT_ID=your-chat-id

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-token

# 服务器运行选项
APP_ROOT=monitor
HOST=0.0.0.0
PORT=8000
RUN_BACKGROUND=true
QUESTIONNAIRE_HELPER_DIR=questionnaire-helper
FORM_RUNNER_MODE=fake

# 七人 PWA MVP 本地测试配置
WEB_PUSH_MODE=fake
WEB_PUSH_PUBLIC_KEY=your-public-key
WEB_PUSH_PRIVATE_KEY=your-private-key
WEB_PUSH_SUBJECT=your-email@qq.com

TEAM_ADMIN_USERNAME=admin
TEAM_ADMIN_PASSWORD=change-me
TEAM_ADMIN_DISPLAY_NAME=示例管理员
SESSION_COOKIE_SECURE=false
